# Copy this file to `.env.local` and fill in your own keys.
# `.env.local` is gitignored — never commit your real keys.
#
# Used ONLY by Node scripts under scripts/ and by the CI enrichment step.
# These keys are NOT inlined into the public Vite bundle anymore — admin-only
# search keys live in the admin user's localStorage (Settings → Advanced).

# TMDB v3 read-only API key — https://www.themoviedb.org/settings/api
# Used by scripts/enrich-static.mjs and other one-off scripts.
VITE_TMDB_API_KEY=

# RAWG.io API key — https://rawg.io/apidocs
# Used by scripts/add-rawg.mjs, scripts/rebuild-games-from-rawg.mjs.
VITE_RAWG_API_KEY=

# Watchmode API key — https://api.watchmode.com/
# Used by scripts/enrich-static.mjs only (server-side).
VITE_WATCHMODE_API_KEY=

# SteamGridDB API key (optional, for vertical posters of mobile/retro games
# Steam CDN doesn't cover) — https://www.steamgriddb.com/profile/preferences/api
VITE_STEAMGRIDDB_API_KEY=
